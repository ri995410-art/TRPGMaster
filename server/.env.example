# 硅基流动 SiliconFlow API
SILICONFLOW_API_KEY=your-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 对话模型（所有Agent默认）
AI_DEFAULT_MODEL=nex-agi/Nex-N2-Pro

# Per-Agent模型覆盖（可选，不设则用AI_DEFAULT_MODEL）
# AI_NARRATIVE_MODEL=nex-agi/Nex-N2-Pro
# AI_NOVEL_MODEL=nex-agi/Nex-N2-Pro
# AI_RULES_MODEL=nex-agi/Nex-N2-Pro
# AI_COMBAT_MODEL=nex-agi/Nex-N2-Pro
# AI_NPC_MODEL=nex-agi/Nex-N2-Pro
# AI_FACTION_MODEL=nex-agi/Nex-N2-Pro
# AI_MEMORY_COMPRESSOR_MODEL=nex-agi/Nex-N2-Pro
# AI_SCENE_DIRECTOR_MODEL=nex-agi/Nex-N2-Pro
# AI_IMAGE_DIRECTOR_MODEL=nex-agi/Nex-N2-Pro
# AI_INTENT_PARSER_MODEL=nex-agi/Nex-N2-Pro

# 语音转文字模型
AI_STT_MODEL=TeleAI/TeleSpeechASR

# 文生图模型
AI_IMAGE_MODEL=Kwai-Kolors/Kolors
